#!/usr/bin/env bash
# Start or attach to a pi tmux session for the current worktree.
# Must be run from inside a git worktree.

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PI_BIN="$SCRIPT_DIR/node_modules/.bin/pi"
MERIDIAN_BIN="$SCRIPT_DIR/node_modules/.bin/meridian"
MERIDIAN_PORT="${MERIDIAN_PORT:-3456}"

# Validate we're in a git worktree
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: not inside a git repository." >&2
  exit 1
fi

WORKTREE_ROOT=$(git rev-parse --show-toplevel)

# Warn if in the main worktree (i.e. .git is a directory, not a file)
if [ -d "$WORKTREE_ROOT/.git" ]; then
  echo "Warning: you're in the main worktree. Use 'wt <name>' to switch to a worktree first." >&2
  exit 1
fi

WORKTREE_NAME=$(basename "$WORKTREE_ROOT")
SESSION="$WORKTREE_NAME"

# Rename cmux workspace to the folder name (if running inside cmux)
if [[ -n "${CMUX_WORKSPACE_ID:-}" ]]; then
  cmux rename-workspace "$WORKTREE_NAME" 2>/dev/null || true
fi

# Helper: switch-client if inside tmux, otherwise attach
tmux_connect() {
  if [ -n "$TMUX" ]; then
    exec tmux switch-client -t "$1"
  else
    exec tmux attach-session -t "$1"
  fi
}

# If session already exists, kill it and rebuild
if tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux kill-session -t "$SESSION"
fi

# Window 1: Proxy (meridian — bridges pi → Claude Max)
# Skip launch if another meridian is already bound to the port.
tmux new-session -d -s "$SESSION" -n "proxy" -c "$WORKTREE_ROOT"
tmux send-keys -t "$SESSION:proxy" \
  "if nc -z 127.0.0.1 $MERIDIAN_PORT 2>/dev/null; then echo \"meridian already running on :$MERIDIAN_PORT\"; else $MERIDIAN_BIN; fi" Enter
tmux set-window-option -t "$SESSION:proxy" automatic-rename off

# Window 2: Agent (pi, routed through meridian)
# Waits for meridian's port to open before launching pi.
tmux new-window -t "$SESSION" -n "agent" -c "$WORKTREE_ROOT"
tmux send-keys -t "$SESSION:agent" \
  "until nc -z 127.0.0.1 $MERIDIAN_PORT 2>/dev/null; do sleep 0.2; done && ANTHROPIC_API_KEY=x ANTHROPIC_BASE_URL=http://127.0.0.1:$MERIDIAN_PORT $PI_BIN" Enter
tmux set-window-option -t "$SESSION:agent" automatic-rename off

# Window 3: Review (tuicr)
tmux new-window -t "$SESSION" -n "review" -c "$WORKTREE_ROOT"
tmux send-keys -t "$SESSION:review" "tuicr" Enter
tmux set-window-option -t "$SESSION:review" automatic-rename off

# Window 4: Terminal
tmux new-window -t "$SESSION" -n "terminal" -c "$WORKTREE_ROOT"

# Start on agent window
tmux select-window -t "$SESSION:agent"

tmux_connect "$SESSION"
