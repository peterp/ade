#!/usr/bin/env bash
# wt — git worktree switcher
#
# Usage:
#   wt              — interactive fzf picker
#   wt <name>       — switch to worktree matching name/branch (fuzzy)
#   wt add <url|desc>          — generate a slug via wt-name, create worktree + branch, switch
#   wt add -r <branch>         — use <branch> as-is, skip name generation
#   wt add -b <base> ...       — base the new branch off <base> instead of current HEAD
#   wt exit                    — switch back to the main worktree

set -euo pipefail

if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "Error: not inside a git repository." >&2
  exit 1
fi

_wt_cd() {
  local path="$1"
  if [ -n "${TMUX:-}" ]; then
    tmux send-keys "cd $(printf '%q' "$path")" Enter
  else
    cd "$path" && exec "$SHELL"
  fi
}

cmd="${1:-}"

# --- wt add <branch|url|description> ----------------------------------------
if [[ "$cmd" == "add" ]]; then
  shift
  raw=false
  base=""
  input=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -r|--raw)
        raw=true
        shift
        ;;
      -b|--base)
        if [[ $# -lt 2 ]]; then
          echo "Error: $1 requires a branch argument." >&2
          exit 1
        fi
        base="$2"
        shift 2
        ;;
      --)
        shift
        input="${1:-}"
        break
        ;;
      -*)
        echo "Unknown flag: $1" >&2
        exit 1
        ;;
      *)
        input="$1"
        shift
        break
        ;;
    esac
  done
  if [[ -z "$input" ]]; then
    echo "Usage: wt add [-r] [-b <base-branch>] <branch|url|description>" >&2
    exit 1
  fi
  if $raw; then
    branch="$input"
    echo "Worktree name: $branch" >&2
  else
    echo "Generating worktree name..." >&2
    branch=$(wt-name "$input")
    echo "Worktree name: $branch" >&2
  fi
  remote_url=$(git remote get-url origin 2>/dev/null) || {
    echo "Error: no origin remote found." >&2
    exit 1
  }
  org_repo=$(echo "$remote_url" | sed -E 's#.*[:/]([^/]+)/([^/]+)(\.git)?$#\1/\2#')
  dest="$HOME/wt/$org_repo/$branch"
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    if [[ -n "$base" ]]; then
      echo "Warning: branch '$branch' already exists; ignoring -b $base." >&2
    fi
    git worktree add "$dest" "$branch"
  else
    if [[ -n "$base" ]]; then
      echo "Basing '$branch' off '$base'" >&2
      git worktree add -b "$branch" "$dest" "$base"
    else
      git worktree add -b "$branch" "$dest"
    fi
  fi
  _wt_cd "$dest"
  exit 0
fi

# --- wt exit ----------------------------------------------------------------
if [[ "$cmd" == "exit" ]]; then
  main_wt=$(git worktree list --porcelain | awk '/^worktree / { print $2; exit }')
  if [[ -z "$main_wt" ]]; then
    echo "Error: could not determine main worktree." >&2
    exit 1
  fi
  _wt_cd "$main_wt"
  exit 0
fi

# --- wt <name> (fuzzy match) ------------------------------------------------
if [[ -n "$cmd" ]]; then
  match=$(git worktree list --porcelain | awk -v name="$cmd" '
    /^worktree / { path = $2 }
    /^branch /   {
      branch = $2; sub(".*/", "", branch)
      dir = path; sub(".*/", "", dir)
      if (tolower(dir) ~ tolower(name) || tolower(branch) ~ tolower(name)) print path
    }
  ' | head -1)
  if [[ -z "$match" ]]; then
    echo "No worktree matching: $cmd" >&2
    git worktree list | tail -n +2 >&2
    exit 1
  fi
  _wt_cd "$match"
  exit 0
fi

# --- wt (interactive fzf picker) --------------------------------------------
selection=$(git worktree list --porcelain \
  | awk '
      /^worktree / { path = $2 }
      /^branch /   { branch = $2; sub("refs/heads/", "", branch) }
      /^$/         { if (path && branch) print path "\t" branch; path=""; branch="" }
      END          { if (path && branch) print path "\t" branch }
    ' \
  | fzf --with-nth=2 \
        --preview='git -C {1} log --oneline --color=always -20' \
        --preview-window=right:50% \
        --prompt="worktree> " \
        --delimiter=$'\t' \
        --height=40%)

[ -z "$selection" ] && exit 0

_wt_cd "$(echo "$selection" | cut -f1)"
